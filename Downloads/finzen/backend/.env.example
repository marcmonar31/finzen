# ── Base ──────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/finzen.db
ENVIRONMENT=local   # "local" | "produccion"

# ── Supabase (requerido en ENVIRONMENT=produccion) ────────────────────────────
# Obtén estos valores en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_JWT_SECRET=tu-jwt-secret   # Settings → API → JWT Secret

# ── PostgreSQL (producción) ───────────────────────────────────────────────────
# Reemplaza DATABASE_URL con tu URL de Neon o Supabase Postgres:
# DATABASE_URL=postgresql://user:pass@host:5432/finzen

# ── Email (opcional, para invitaciones) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASSWORD=app-password-aqui
FROM_EMAIL=noreply@finzen.app

# ── Deploy ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://finzen.vercel.app
